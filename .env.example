# ============================================================
# DENGUE OUTBREAK PREDICTION - RD
# .env.example - Copiar como .env y completar valores reales
# NUNCA subir .env al repositorio
# ============================================================

# --- AUTENTICACIÓN DE APLICACIÓN ---
APP_PASSWORD=cambiar_por_password_seguro
APP_SECRET_KEY=generar_clave_secreta_aleatoria_32_chars

# --- CIFRADO AES-256 ---
ENCRYPTION_KEY=generar_clave_aes256_base64_aqui
ENCRYPTION_SALT=generar_salt_aleatorio_aqui

# --- API KEYS ---
API_KEY_SECRET=tu_api_key_secreta_para_fastapi
API_KEY_HEADER=X-API-Key

# --- BASE DE DATOS (opcional) ---
DATABASE_URL=postgresql://usuario:password@localhost:5432/dengue_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dengue_db
DB_USER=dengue_user
DB_PASSWORD=password_seguro

# --- CORREO ELECTRÓNICO (alertas) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASSWORD=tu_app_password_gmail
EMAIL_FROM=alertas.dengue.rd@gmail.com
EMAIL_TO_ALERTS=epidemiologia@msp.gob.do,alertas@paho.org

# --- FUENTES DE DATOS EXTERNAS ---
PAHO_API_URL=https://www3.paho.org/data/index.php/en/
ONAMET_API_URL=https://onamet.gob.do/api/
ONE_API_URL=https://www.one.gob.do/api/
MSP_SINAVE_URL=https://digepi.gob.do/

# --- CONFIGURACIÓN MODELO ---
MODEL_RETRAIN_THRESHOLD=0.88
MODEL_RETRAIN_SCHEDULE=weekly
EPIDEMIC_THRESHOLD=65
ALERT_THRESHOLD=80

# --- FASTAPI ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_WORKERS=4

# --- STREAMLIT ---
STREAMLIT_PORT=8501
STREAMLIT_HOST=0.0.0.0

# --- SCHEDULER ---
SCHEDULER_TIMEZONE=America/Santo_Domingo
DATA_FETCH_SCHEDULE=0 6 * * MON
MODEL_RETRAIN_SCHEDULE=0 8 * * MON
ALERT_CHECK_SCHEDULE=0 */6 * * *

# --- LOGGING ---
LOG_LEVEL=INFO
LOG_FILE=logs/dengue_system.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# --- ENTORNO ---
ENVIRONMENT=development
DEBUG=false
